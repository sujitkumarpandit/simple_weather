generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"

}

model User {
  id            String          @id @default(cuid())
  email         String?         @unique
  name          String?
  favorites     FavoriteLocation[]
  preferences   Json?           // { units: 'metric' | 'imperial', theme: 'light' | 'dark' }
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model FavoriteLocation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  lat       Float
  lon       Float
  country   String?
  createdAt DateTime @default(now())
}

model WeatherCache {
  key       String   @id // lat,lon,units
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}
